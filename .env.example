# Copy this file to .env for local dev, or paste these keys into your
# hosting platform's environment variables dashboard for production.

# ===== Server =====
PORT=4000
NODE_ENV=production
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ===== Database (MongoDB - required) =====
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/travela?retryWrites=true&w=majority

# ===== Auth =====
JWT_SECRET=
JWT_EXPIRES=7d

# ===== CORS / cross-service URLs =====
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
BASE_URL=https://your-backend.onrender.com

# ===== Recommendation microservice (RS) =====
# Public URL of the deployed recommendation-service (FastAPI/Docker)
RECOMMENDATION_API=https://your-recommendation-service.onrender.com

# ===== Email (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===== Google OAuth =====
# Redirect URI must be registered in Google Cloud Console for this exact URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback

# ===== VNPay =====
# Return URL must match what's registered in the VNPay merchant portal
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=https://your-backend.onrender.com/api/payment/vnpay/return

# ===== SePay =====
SEPAY_MERCHANT_ID=
SEPAY_API_KEY=
SEPAY_BANK_CODE=VCB
SEPAY_ACCOUNT_NO=
SEPAY_ACCOUNT_NAME=

# ===== MoMo =====
# Redirect/IPN URLs must match what's registered in the MoMo merchant portal
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://your-backend.onrender.com/api/payment/momo/return
MOMO_IPN_URL=https://your-backend.onrender.com/api/payment/momo/ipn

BOOKING_DEPOSIT_RATE=0.2

# ===== Cloudinary (image hosting) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=travela/avatars

# ===== Smart Tour Assistant (Claude API) =====
ANTHROPIC_API_KEY=
CHATBOT_MODEL=claude-haiku-4-5-20251001
